{
  "name": "jizy-api",
  "version": "2.2.0",
  "browser": "dist/js/jizy-api.min.js",
  "main": "lib/index.js",
  "type": "module",
  "jizy": "dist/",
  "files": [
    "dist/*",
    "lib/*"
  ],
  "scripts": {
    "jpack:export": "node ./cli/jpack.js --action build --name perso",
    "jpack:export-debug": "node ./cli/jpack.js --action build --name perso --debug",
    "jpack:dist": "node ./cli/jpack.js",
    "jpack:dist-debug": "node ./cli/jpack.js --debug",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/*.test.js"
    ],
    "transform": {}
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joffreydemetz/jizy-api"
  },
  "keywords": [
    "JiZy",
    "Fetch",
    "Ajax",
    "Transport"
  ],
  "author": "Joffrey Demetz <joffrey.demetz@gmail.com> (https://joffreydemetz.com/)",
  "license": "MIT",
  "description": "A lightweight API transport library (fetch/xhr proxies)",
  "homepage": "https://jizy.joffreydemetz.com/api",
  "devDependencies": {
    "jest": "^29.7.0",
    "jizy-packer": "^2.1.44"
  },
  "optionalDependencies": {
    "jizy-messenger": "^2.1.9"
  }
}